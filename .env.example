# ==========================================
# SECURITY CONFIGURATION (JWT)
# ==========================================
# The JWT secret must be a secure, long string (at least 32 characters) or Base64 encoded.
JWT_SECRET=replace_this_with_a_very_long_and_secure_secret_key_for_jwt

# ==========================================
# EXTERNAL APIs
# ==========================================
# Get your API key from Google Cloud Console (Books API)
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here